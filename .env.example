# --- Database ---
DATABASE_URL=postgresql://ci:ci@localhost:5433/codebase_investigator?schema=public

# --- API server ---
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# --- Repo cache ---
REPO_CACHE_DIR=./.cache/repos

# --- LLM routing ---
# Format: <provider>:<model>. Configured providers: openai, gemini, groq, openai-compat.
# Free-tier defaults (no card required):
AGENT_MODEL=gemini:gemini-2.0-flash
AUDITOR_MODEL=groq:llama-3.3-70b-versatile
EMBEDDING_MODEL=gemini:text-embedding-004

# Admin token for runtime model overrides via POST /admin/settings (X-Admin-Token header).
# Setting agent_model / auditor_model / embedding_model in the DB overrides env without restart.
ADMIN_TOKEN=

# --- Auth (Google via NextAuth on web; HMAC-signed forwarded header to api) ---
# AUTH_SHARED_SECRET MUST be identical between web and api.
AUTH_SHARED_SECRET=
# Comma-separated emails. Empty = open (dev only). Set on BOTH services.
ALLOWED_EMAILS=

# Web-only NextAuth config (set in web service env):
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=<openssl rand -hex 32>
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# When you have OpenAI credits, switch to:
# AGENT_MODEL=openai:gpt-5
# AUDITOR_MODEL=openai:gpt-5-mini

# --- Google Gemini (free tier — get key at https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
# GEMINI_BASE_URL defaults to https://generativelanguage.googleapis.com/v1beta/openai/

# --- Groq (free tier — get key at https://console.groq.com/keys) ---
GROQ_API_KEY=
# GROQ_BASE_URL defaults to https://api.groq.com/openai/v1

# --- OpenAI ---
OPENAI_API_KEY=
# OPENAI_BASE_URL defaults to https://api.openai.com/v1

# --- Generic OpenAI-compatible slot (Moonshot/Kimi, MiniMax, DeepSeek, OpenRouter, ...) ---
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
