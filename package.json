{
  "name": "codebase-investigator",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "api",
    "web",
    "shared"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:api": "npm --workspace api run start:dev",
    "dev:web": "npm --workspace web run dev",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:migrate": "npm --workspace api run prisma:migrate",
    "prisma:generate": "npm --workspace api run prisma:generate"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
